<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ================================================================
         LibrarySystem Inspector — Design Tokens (WPF ResourceDictionary)
           tokens/colors.css · tokens/typography.css · tokens/spacing.css
         All hex values are ARGB (#AARRGGBB) where alpha < FF is needed.
         ================================================================ -->

    <!-- ── Surface Brushes ── -->
    <SolidColorBrush x:Key="SurfaceApp"    Color="#1E1E1E"/>
    <SolidColorBrush x:Key="SurfacePanel"  Color="#252526"/>
    <SolidColorBrush x:Key="SurfaceCard"   Color="#2D2D30"/>
    <SolidColorBrush x:Key="SurfaceInput"  Color="#333337"/>
    <SolidColorBrush x:Key="SurfaceRaised" Color="#3E3E42"/>
    <SolidColorBrush x:Key="SurfaceWell"   Color="#0F0F0F"/>

    <!-- ── Border Brushes ── -->
    <SolidColorBrush x:Key="BorderSubtle"  Color="#3F3F46"/>
    <SolidColorBrush x:Key="BorderStrong"  Color="#52525B"/>

    <!-- ── Text Brushes ── -->
    <SolidColorBrush x:Key="TextPrimary"   Color="#F1F1F1"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="TextTertiary"  Color="#AAAAAA"/>
    <SolidColorBrush x:Key="TextMuted"     Color="#6E6E76"/>
    <SolidColorBrush x:Key="TextDisabled"  Color="#5A5A62"/>
    <SolidColorBrush x:Key="TextOnAccent"  Color="#FFFFFF"/>

    <!-- ── Accent Brushes (LibrarySystem electric violet) ── -->
    <SolidColorBrush x:Key="AccentText"    Color="#C49BFF"/>
    <SolidColorBrush x:Key="AccentFill"    Color="#7C16FF"/>
    <SolidColorBrush x:Key="AccentHover"   Color="#9D4DFF"/>
    <SolidColorBrush x:Key="AccentPress"   Color="#5311CC"/>

    <!-- ── Severity Brushes (calm, not neon) ── -->
    <SolidColorBrush x:Key="SevInfo"       Color="#3FB950"/>
    <SolidColorBrush x:Key="SevWarning"    Color="#E3B341"/>
    <SolidColorBrush x:Key="SevCritical"   Color="#F85149"/>
    <!-- 13–14% alpha washes: 0x21 ≈ 13%, 0x24 ≈ 14% -->
    <SolidColorBrush x:Key="SevInfoBg"     Color="#213FB950"/>
    <SolidColorBrush x:Key="SevWarningBg"  Color="#24E3B341"/>
    <SolidColorBrush x:Key="SevCriticalBg" Color="#24F85149"/>

    <!-- ── Graph Brushes ── -->
    <SolidColorBrush x:Key="NodeBookRail"   Color="#7C16FF"/>
    <SolidColorBrush x:Key="NodeAuthorRail" Color="#E3B341"/>
    <SolidColorBrush x:Key="EdgeLine"       Color="#444444"/>
    <SolidColorBrush x:Key="EdgeLineActive" Color="#9D4DFF"/>

    <!-- ── App Logo Mark (mirrors logo-mark.svg) ── -->
    <!-- Two purple nodes (solid) + two author nodes (gold-ring) connected by gray edges -->
    <DrawingImage x:Key="AppLogoMark">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <!-- Background: dark rounded square -->
                <GeometryDrawing Brush="#1E1E1E">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,32,32" RadiusX="5" RadiusY="5"/>
                    </GeometryDrawing.Geometry>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#3F3F46" Thickness="1"/>
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
                <!-- Graph edges: X cross -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#444444" Thickness="1.5"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="9,10" EndPoint="22,22"/>
                            <LineGeometry StartPoint="22,10" EndPoint="9,22"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Violet book nodes (top-left, bottom-right) -->
                <GeometryDrawing Brush="#9333FF">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <EllipseGeometry Center="9,10"  RadiusX="3.4" RadiusY="3.4"/>
                            <EllipseGeometry Center="22,22" RadiusX="3.4" RadiusY="3.4"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Gold-ring author nodes (top-right, bottom-left) -->
                <GeometryDrawing Brush="#252526">
                    <GeometryDrawing.Pen>
                        <Pen Brush="#E3B341" Thickness="1.6"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <EllipseGeometry Center="22,10" RadiusX="3.4" RadiusY="3.4"/>
                            <EllipseGeometry Center="9,22"  RadiusX="3.4" RadiusY="3.4"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ================================================================
         BUTTON STYLES
         ================================================================ -->

    <!-- Primary button: violet fill, white text -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Foreground"           Value="White"/>
        <Setter Property="FontFamily"           Value="Segoe UI"/>
        <Setter Property="FontSize"             Value="13"/>
        <Setter Property="FontWeight"           Value="SemiBold"/>
        <Setter Property="Height"               Value="30"/>
        <Setter Property="Cursor"               Value="Hand"/>
        <Setter Property="FocusVisualStyle"     Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bdr"
                            Background="#7C16FF"
                            CornerRadius="4"
                            Padding="14,0"
                            BorderThickness="1"
                            BorderBrush="Transparent"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bdr" Property="Background" Value="#9D4DFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bdr" Property="Background" Value="#5311CC"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bdr" Property="Background" Value="#3E3E42"/>
                            <Setter Property="Foreground" Value="#5A5A62"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Secondary button: raised surface, subtle border -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Foreground"       Value="#F1F1F1"/>
        <Setter Property="FontFamily"       Value="Segoe UI"/>
        <Setter Property="FontSize"         Value="12"/>
        <Setter Property="FontWeight"       Value="Medium"/>
        <Setter Property="Height"           Value="24"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bdr"
                            Background="#3E3E42"
                            CornerRadius="4"
                            Padding="10,0"
                            BorderThickness="1"
                            BorderBrush="#3F3F46"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bdr" Property="Background"    Value="#52525B"/>
                            <Setter TargetName="Bdr" Property="BorderBrush"   Value="#52525B"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bdr" Property="Background" Value="#333337"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bdr" Property="Background" Value="#252526"/>
                            <Setter Property="Foreground" Value="#5A5A62"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Monitoring ToggleButton: primary (violet) when unchecked (not monitoring),
         secondary (gray) when checked (monitoring active). -->
    <Style x:Key="MonitoringToggle" TargetType="ToggleButton">
        <Setter Property="Foreground"       Value="#F1F1F1"/>
        <Setter Property="FontFamily"       Value="Segoe UI"/>
        <Setter Property="FontSize"         Value="12"/>
        <Setter Property="Height"           Value="24"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bdr"
                            Background="#7C16FF"
                            CornerRadius="4"
                            Padding="10,0"
                            BorderThickness="1"
                            BorderBrush="Transparent"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Checked = monitoring active → secondary style -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bdr" Property="Background"  Value="#3E3E42"/>
                            <Setter TargetName="Bdr" Property="BorderBrush" Value="#3F3F46"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bdr" Property="Background" Value="#52525B"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bdr" Property="Background" Value="#333337"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================
         INSPECTOR TEXTBOX
         Label lives outside; this styles the field itself.
         ================================================================ -->
    <Style x:Key="InspectorTextBox" TargetType="TextBox">
        <Setter Property="Background"              Value="#333337"/>
        <Setter Property="Foreground"              Value="#F1F1F1"/>
        <Setter Property="CaretBrush"              Value="#F1F1F1"/>
        <Setter Property="SelectionBrush"          Value="#7C16FF"/>
        <Setter Property="SelectionOpacity"        Value="0.45"/>
        <Setter Property="FontFamily"              Value="Segoe UI"/>
        <Setter Property="FontSize"                Value="13"/>
        <Setter Property="Height"                  Value="30"/>
        <Setter Property="Padding"                 Value="10,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="BorderThickness"         Value="0"/>
        <Setter Property="FocusVisualStyle"        Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bdr"
                            Background="{TemplateBinding Background}"
                            BorderBrush="#3F3F46"
                            BorderThickness="1"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"
                                      Focusable="False"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bdr" Property="BorderBrush" Value="#52525B"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bdr" Property="BorderBrush" Value="#9D4DFF"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bdr" Property="Background" Value="#252526"/>
                            <Setter Property="Foreground" Value="#5A5A62"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================
         WAF CONSOLE LISTBOX + ITEM
         ================================================================ -->
    <Style x:Key="WafConsoleListBox" TargetType="ListBox">
        <Setter Property="Background"                               Value="#0F0F0F"/>
        <Setter Property="BorderThickness"                          Value="0"/>
        <Setter Property="Padding"                                  Value="0,6"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="VirtualizingPanel.IsVirtualizing"         Value="True"/>
        <Setter Property="VirtualizingPanel.VirtualizationMode"     Value="Recycling"/>
        <Setter Property="FocusVisualStyle"                         Value="{x:Null}"/>
    </Style>

    <Style x:Key="WafLogItem" TargetType="ListBoxItem">
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="Padding"          Value="0"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bdr" Background="{TemplateBinding Background}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bdr" Property="Background" Value="Transparent"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bdr" Property="Background" Value="#09FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
