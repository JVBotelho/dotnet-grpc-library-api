<Window x:Class="LibrarySystem.Tools.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:b="clr-namespace:LibrarySystem.Tools.Behaviors"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:LibrarySystem.Tools.ViewModels"
        xmlns:cv="clr-namespace:LibrarySystem.Tools.Converters"
        mc:Ignorable="d"
        Title="LibrarySystem — Service Graph Inspector"
        Height="680" Width="1200" MinHeight="500" MinWidth="900"
        Background="#1E1E1E" Foreground="#F1F1F1"
        Icon="{StaticResource AppLogoMark}">

    <d:Window.DataContext>
        <vm:MainViewModel/>
    </d:Window.DataContext>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme/InspectorTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <cv:NodeTypeToRailColorConverter  x:Key="NodeTypeToRailColor"/>
            <cv:WafActionToColorConverter     x:Key="WafActionToColor"/>
            <cv:StatusTextToColorConverter    x:Key="StatusTextToColor"/>
            <cv:NullToVisibilityConverter     x:Key="NullToVisibility"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>   <!-- Toolbar                 -->
            <RowDefinition Height="2*"/>   <!-- Graph canvas + inspector -->
            <RowDefinition Height="200"/>  <!-- WAF security console     -->
        </Grid.RowDefinitions>

        <!-- ============================================================
             ROW 0 — Toolbar
             ============================================================ -->
        <Border Grid.Row="0"
                Background="#252526"
                BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <!-- Left: brand icon + eyebrow title + topology status -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Graph topology icon -->
                    <TextBlock Text="&#xE968;"
                               FontFamily="Segoe MDL2 Assets, Segoe UI Symbol" FontSize="14"
                               Foreground="#7C16FF"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="SERVICE INSPECTOR"
                               FontFamily="Segoe UI" FontWeight="Bold" FontSize="11"
                               Foreground="#C49BFF"
                               VerticalAlignment="Center"/>
                    <!-- Topology load status (muted, transient) -->
                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0"
                                 Fill="{Binding StatusMessage, Converter={StaticResource StatusTextToColor}}"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontFamily="Consolas" FontSize="12"
                                   Foreground="{Binding StatusMessage, Converter={StaticResource StatusTextToColor}}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right: WAF stream status + Refresh button + Expand -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- WAF streaming status surfaced to the top bar -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0"
                                 Fill="{Binding WafLogs.StatusText, Converter={StaticResource StatusTextToColor}}"/>
                        <TextBlock Text="{Binding WafLogs.StatusText}"
                                   FontFamily="Consolas" FontSize="12"
                                   Foreground="{Binding WafLogs.StatusText, Converter={StaticResource StatusTextToColor}}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Refresh Topology (icon + label) -->
                    <Button VerticalAlignment="Center"
                            Command="{Binding LoadGraphDataCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets, Segoe UI Symbol" FontSize="12" Text="&#xE72C;"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Refresh Topology" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Expand / Maximise toggle -->
                    <Button x:Name="BtnExpand" VerticalAlignment="Center"
                            Width="24"
                            Style="{StaticResource SecondaryButton}"
                            Click="OnExpandClick"
                            ToolTip="Toggle fullscreen">
                        <TextBlock FontFamily="Segoe MDL2 Assets, Segoe UI Symbol" FontSize="12" Text="&#xE740;"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================================================
             ROW 1 — Graph canvas + Inspector panel
             ============================================================ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Graph canvas (dotted grid) -->
            <ScrollViewer Grid.Column="0"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          PanningMode="Both"
                          Background="#1E1E1E">
                <Grid Width="3000" Height="3000">
                    <!-- Dotted grid: white 1.5px-radius dots on 50px centres -->
                    <Grid.Background>
                        <DrawingBrush TileMode="Tile"
                                      Viewport="0,0,50,50" ViewportUnits="Absolute">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="#1E1E1E">
                                        <GeometryDrawing.Geometry>
                                            <RectangleGeometry Rect="0,0,50,50"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                    <GeometryDrawing>
                                        <GeometryDrawing.Brush>
                                            <SolidColorBrush Color="#0FFFFFFF"/>
                                        </GeometryDrawing.Brush>
                                        <GeometryDrawing.Geometry>
                                            <EllipseGeometry Center="25,25" RadiusX="1.5" RadiusY="1.5"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Grid.Background>

                    <!-- Edges (rendered behind nodes) -->
                    <ItemsControl ItemsSource="{Binding Edges}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Line X1="{Binding X1}" Y1="{Binding Y1}"
                                      X2="{Binding X2}" Y2="{Binding Y2}"
                                      StrokeThickness="2" StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                                      IsHitTestVisible="False">
                                    <Line.Style>
                                        <Style TargetType="Line">
                                            <Setter Property="Stroke" Value="#444444"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Stroke" Value="#9D4DFF"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Line.Style>
                                </Line>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Node cards -->
                    <ItemsControl ItemsSource="{Binding Nodes}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!--
                                    GraphNode card — 200×100px, 4px top type-rail.
                                    Book  node: violet rail  (#7C16FF).
                                    Author node: amber rail  (#E3B341).
                                    Selected:  2px white ring + white glow.
                                -->
                                <Border Width="200" Height="100" CornerRadius="4"
                                        Background="#2D2D30" SnapsToDevicePixels="True">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush"     Value="#3F3F46"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2"
                                                                      Opacity="0.35" Color="Black"/>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BorderBrush"     Value="White"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="White" BlurRadius="15"
                                                                              Opacity="0.4" ShadowDepth="0"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="#52525B"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <i:Interaction.Behaviors>
                                        <b:NodeDragBehavior/>
                                    </i:Interaction.Behaviors>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="4"/>   <!-- Type-accent rail -->
                                            <RowDefinition Height="*"/>   <!-- Title + subtitle  -->
                                            <RowDefinition Height="Auto"/><!-- ID stamp          -->
                                        </Grid.RowDefinitions>

                                        <!-- Type-accent rail (Book = violet, Author = amber) -->
                                        <Border Grid.Row="0" CornerRadius="3,3,0,0"
                                                Background="{Binding NodeType, Converter={StaticResource NodeTypeToRailColor}}"/>

                                        <!-- Title + subtitle -->
                                        <StackPanel Grid.Row="1" Margin="12,10,12,4" VerticalAlignment="Top">
                                            <TextBlock Text="{Binding Title}"
                                                       FontFamily="Segoe UI" FontWeight="Bold" FontSize="13"
                                                       Foreground="#F1F1F1"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Subtitle}"
                                                       FontFamily="Segoe UI" FontSize="12"
                                                       Foreground="#CCCCCC"
                                                       Margin="0,4,0,0"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Bottom row: type icon + label (left) · book ID (right) -->
                                        <Grid Grid.Row="2" Margin="8,0,8,6">
                                            <!-- Type badge: icon glyph + NodeType text, colored like the rail -->
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock FontFamily="Segoe MDL2 Assets, Segoe UI Symbol" FontSize="11"
                                                           Foreground="{Binding NodeType, Converter={StaticResource NodeTypeToRailColor}}"
                                                           VerticalAlignment="Center" Margin="0,0,5,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="&#xE736;"/>  <!-- Book glyph -->
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding NodeType}" Value="Author">
                                                                    <Setter Property="Text" Value="&#xE77B;"/>  <!-- Person glyph -->
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{Binding NodeType}"
                                                           FontFamily="Consolas" FontSize="10"
                                                           Foreground="{Binding NodeType, Converter={StaticResource NodeTypeToRailColor}}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <!-- Domain ID — only meaningful for Book nodes -->
                                            <TextBlock Text="{Binding Id, StringFormat='#{0}'}"
                                                       FontFamily="Consolas" FontSize="10"
                                                       Foreground="#6E6E76"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding NodeType}" Value="Author">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>

            <!-- Inspector panel (300px, right side) -->
            <Border Grid.Column="1"
                    Background="#252526"
                    BorderBrush="#3F3F46" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16" DataContext="{Binding Inspector}">

                        <!-- PROPERTIES eyebrow header -->
                        <TextBlock Text="PROPERTIES"
                                   FontFamily="Segoe UI" FontWeight="Bold" FontSize="11"
                                   Foreground="#C49BFF"
                                   Margin="0,0,0,16"/>

                        <!-- Fields — visible when a node is selected -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedNode}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <!-- Title -->
                            <TextBlock Text="Title"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#AAAAAA" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InspectorTextBox}"/>

                            <!-- Author (disabled for Author-type nodes) -->
                            <TextBlock Text="Author"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#AAAAAA" Margin="0,12,0,5"/>
                            <TextBox Text="{Binding EditAuthor, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsBookNode}"
                                     Style="{StaticResource InspectorTextBox}"/>

                            <!-- Year (mono) -->
                            <TextBlock Text="Year"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#AAAAAA" Margin="0,12,0,5"/>
                            <TextBox Text="{Binding EditYear, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas"
                                     Style="{StaticResource InspectorTextBox}"/>

                            <!-- Save button (icon + label) -->
                            <Button Command="{Binding SaveChangesCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,18,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock FontFamily="Segoe MDL2 Assets, Segoe UI Symbol" FontSize="13" Text="&#xE74E;"
                                               VerticalAlignment="Center" Margin="0,0,7,0"/>
                                    <TextBlock Text="Save Changes" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Hint -->
                            <TextBlock Text="Changes are sent directly to the Core Service via gRPC and persisted in PostgreSQL."
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#6E6E76"
                                       TextWrapping="Wrap"
                                       FontStyle="Italic"
                                       Margin="0,12,0,0" LineHeight="18"/>
                        </StackPanel>

                        <!-- Placeholder — shown when no node is selected -->
                        <TextBlock Text="Select a node to edit details."
                                   FontFamily="Segoe UI" FontSize="13"
                                   Foreground="#6E6E76" FontStyle="Italic"
                                   HorizontalAlignment="Center" Margin="0,48,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedNode}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ============================================================
             ROW 2 — Security Console (WAF)
             ============================================================ -->
        <Border Grid.Row="2"
                Background="#0F0F0F"
                BorderBrush="#3F3F46" BorderThickness="0,1,0,0">
            <Grid DataContext="{Binding WafLogs}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Console header row -->
                <Border Grid.Row="0"
                        Background="#1E1E1E"
                        BorderBrush="#3F3F46" BorderThickness="0,0,0,1"
                        Padding="12,7">
                    <Grid VerticalAlignment="Center">
                        <!-- Left: waveform icon + label + stream status indicator -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="{StaticResource AppLogoMark}"
                                   Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="SECURITY CONSOLE (WAF)"
                                       FontFamily="Segoe UI" FontWeight="Bold" FontSize="11"
                                       Foreground="#CCCCCC"
                                       VerticalAlignment="Center"
                                       Margin="0,0,16,0"/>

                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0"
                                     Fill="{Binding StatusText, Converter={StaticResource StatusTextToColor}}"/>
                            <TextBlock Text="{Binding StatusText}"
                                       FontFamily="Consolas" FontSize="12"
                                       Foreground="{Binding StatusText, Converter={StaticResource StatusTextToColor}}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Right: Start/Stop Monitoring toggle -->
                        <ToggleButton HorizontalAlignment="Right" VerticalAlignment="Center"
                                      IsChecked="{Binding IsMonitoring}"
                                      Content="{Binding MonitoringButtonText}"
                                      Width="140"
                                      Style="{StaticResource MonitoringToggle}"/>
                    </Grid>
                </Border>

                <!-- Log rows -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Logs}"
                         Style="{StaticResource WafConsoleListBox}"
                         ItemContainerStyle="{StaticResource WafLogItem}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!--
                                LogRow layout (3 columns, monospaced, tabular):
                                  84px — timestamp (muted)
                                 110px — severity dot + action (severity color, bold)
                                   1* — details (secondary text, ellipsis)
                            -->
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="84"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Timestamp -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Timestamp}"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="#6E6E76"
                                           Padding="12,3,0,3"/>

                                <!-- Severity dot + action label -->
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="0,3">
                                    <Ellipse Width="6" Height="6"
                                             VerticalAlignment="Center" Margin="0,0,6,0"
                                             Fill="{Binding Action, Converter={StaticResource WafActionToColor}}"/>
                                    <TextBlock Text="{Binding Action}"
                                               FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                               Foreground="{Binding Action, Converter={StaticResource WafActionToColor}}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Details -->
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Details}"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="#CCCCCC"
                                           Padding="0,3,12,3"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ============================================================
             Toast overlay — bottom-right, spans all rows, high z-order.
             Bound to Notifications.ActiveToast on MainViewModel.
             ============================================================ -->
        <Grid Grid.Row="0" Grid.RowSpan="3"
              IsHitTestVisible="False" Panel.ZIndex="50">
            <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="18" IsHitTestVisible="True"
                    Width="320" CornerRadius="4"
                    Background="#2D2D30"
                    BorderBrush="#3F3F46" BorderThickness="1"
                    Padding="12,11"
                    Visibility="{Binding Notifications.ActiveToast, Converter={StaticResource NullToVisibility}}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.5" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Tone dot -->
                    <Ellipse Grid.Column="0" Width="8" Height="8"
                             VerticalAlignment="Top" Margin="0,4,10,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#C49BFF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Notifications.ActiveToast.Tone}"
                                                 Value="Success">
                                        <Setter Property="Fill" Value="#3FB950"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Notifications.ActiveToast.Tone}"
                                                 Value="Error">
                                        <Setter Property="Fill" Value="#F85149"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Notifications.ActiveToast.Tone}"
                                                 Value="Warning">
                                        <Setter Property="Fill" Value="#E3B341"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>

                    <!-- Title + message -->
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Notifications.ActiveToast.Title}"
                                   FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#F1F1F1"/>
                        <TextBlock Text="{Binding Notifications.ActiveToast.Message}"
                                   FontFamily="Consolas" FontSize="12"
                                   Foreground="#CCCCCC"
                                   Margin="0,3,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>
