# Example environment variables for local development
# Copy this file to .env and change the values appropriately.

# The password for the PostgreSQL database
DB_PASSWORD=SecureDbPassword123!

# The ASP.NET Core environment
ASPNETCORE_ENVIRONMENT=Development

# gRPC API Key — shared coarse gate between server and kiosk client.
# Both values MUST match. The real device identity is enforced by the mTLS cert CN,
# not by this key alone. Change both before deploying to any shared environment.
GRPC_API_KEY=change-this-api-key-in-prod
KIOSK_API_KEY=change-this-api-key-in-prod